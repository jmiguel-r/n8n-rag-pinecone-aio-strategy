              "batchSize": 1,
              "batchInterval": 100
            }
          }
        }
      },
      "id": "97d4cd5f-75da-4430-8626-323192af6ca5",
      "name": "Generate Embeddings (OpenAI text-embedding-3-small)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1040,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build Pinecone upsert payload\nconst embeddingData = $input.item.json;\nconst chunkData = $('Text Chunker (500t / 100t overlap)').item.json;\n\nconst vector = $input.item.json.embedding.values;\n\nconst upsertPayload = {\n  vectors: [\n    {\n      id: chunkData.chunkId,\n      values: vector,\n      metadata: {\n        text: chunkData.chunkText,\n        fileName: chunkData.fileName,\n        fileId: chunkData.fileId,\n        chunkIndex: chunkData.chunkIndex,\n        totalChunks: chunkData.totalChunks,\n        source: chunkData.source,\n        createdTime: chunkData.createdTime\n      }\n    }\n  ],\n  namespace: \"aio-strategy-docs\"\n};\n\nreturn [{ json: upsertPayload }];"
      },

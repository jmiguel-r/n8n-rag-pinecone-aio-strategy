        "jsCode": "const result = $input.item.json;\nconst chunkId = $('Build Pinecone Upsert Payload').item.json.vectors[0].id;\n\nconsole.log(`✅ Upserted chunk: ${chunkId}`);\nconsole.log(`Pinecone response:`, JSON.stringify(result));\n\nreturn [{\n  json: {\n    status: 'success',\n    chunkId,\n    upsertedCount: result.upsertedCount || 1,\n    timestamp: new Date().toISOString()\n  }\n}];"

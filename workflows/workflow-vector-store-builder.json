    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\n\n// El Google Drive Trigger ya nos da el nombre e ID\nconst fileName = item.name || 'unknown_file';\nconst fileId = item.id;\nconst mimeType = item.mimeType;\nconst createdTime = item.createdTime;\n\n// Para Google Docs, el texto viene en el campo description o snippet\n// Usamos un texto de muestra por ahora para validar el flujo\nconst rawText = item.description || item.snippet || \n  `AIO Strategy es una consultora de AI y datos B2B con sede en Querétaro, México. \n  Especializada en manufactura, agroindustria y logística en la región Bajío.\n  Servicios: Diagnóstico de madurez de datos, Implementación de pipelines de ML, \n  Automatización de procesos con AI, Dashboards de inteligencia de negocio.\n  Sectores: Manufactura industrial, Agroindustria, Logística y cadena de suministro.`;\n\nreturn [{\n  json: {\n    fileName,\n    fileId,\n    mimeType,\n    createdTime,\n    rawText,\n    source: 'AIO Strategy Knowledge Base'\n  }\n}];"
      },
      "id": "1ac38996-bf60-4171-9aa4-f89154fc8f6c",
      "name": "Extract Text from File",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Chunk text into overlapping segments for better RAG retrieval\n// Strategy: 500 tokens (~2000 chars) with 100-token overlap\nconst CHUNK_SIZE = 2000;\nconst CHUNK_OVERLAP = 400;\n\nconst { rawText, fileName, fileId, createdTime } = $input.item.json;\n\nif (!rawText || rawText.trim().length === 0) {\n  return [];\n}\n\nconst cleanText = rawText\n  .replace(/\\s+/g, ' ')\n  .replace(/[^\\w\\s.,;:!?()\\-áéíóúÁÉÍÓÚñÑüÜ]/g, '')\n  .trim();\n\nconst chunks = [];\nlet start = 0;\nlet chunkIndex = 0;\n\nwhile (start < cleanText.length) {\n  const end = Math.min(start + CHUNK_SIZE, cleanText.length);\n  let chunkText = cleanText.substring(start, end);\n  \n  // Try to break at sentence boundary\n  if (end < cleanText.length) {\n    const lastPeriod = Math.max(\n      chunkText.lastIndexOf('. '),\n      chunkText.lastIndexOf('\\n')\n    );\n    if (lastPeriod > CHUNK_SIZE * 0.7) {\n      chunkText = chunkText.substring(0, lastPeriod + 1);\n    }\n  }\n  \n  if (chunkText.trim().length > 100) {\n    chunks.push({\n      json: {\n        chunkId: `${fileId}_chunk_${chunkIndex}`,\n        chunkIndex,\n        chunkText: chunkText.trim(),\n        fileName,\n        fileId,\n        createdTime,\n        source: 'AIO Strategy Knowledge Base',\n        totalChunks: -1 // placeholder, updated below\n      }\n    });\n    chunkIndex++;\n  }\n  \n  start += CHUNK_SIZE - CHUNK_OVERLAP;\n}\n\n// Update totalChunks\nchunks.forEach(c => { c.json.totalChunks = chunkIndex; });\n\n// Pre-build Gemini request body\nchunks.forEach(c => {\n  c.json.geminiBody = JSON.stringify({\n    model: \"models/text-embedding-004\",\n    content: { parts: [{ text: c.json.chunkText }] }\n  });\n});\n\nreturn chunks;"
      },
      "id": "dde07cc3-1c6e-47a9-af9d-d1a04082b94a",
      "name": "Text Chunker (500t / 100t overlap)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=YOUR_GEMINI_API_KEY",
        "sendHeaders": true,
